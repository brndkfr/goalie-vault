---
layout: none
permalink: /api/v1/categories/index.json
---
{% assign all_categories = "" | split: "" %}{% for post in site.posts %}{% for cat in post.category %}{% unless all_categories contains cat %}{% assign all_categories = all_categories | push: cat %}{% endunless %}{% endfor %}{% endfor %}{% assign all_categories = all_categories | sort %}[{% for cat in all_categories %}{% assign count = 0 %}{% for post in site.posts %}{% if post.category contains cat %}{% assign count = count | plus: 1 %}{% endif %}{% endfor %}{"name":{{ cat | jsonify }},"url":{{ site.url | append: site.baseurl | append: "/api/v1/categories/" | append: cat | append: ".json" | jsonify }},"count":{{ count }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
