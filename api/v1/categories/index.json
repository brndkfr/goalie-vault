---
layout: none
permalink: /api/v1/categories/index.json
---
{% assign all_names = "" | split: "" %}{% for post in site.posts %}{% if post.category %}{% unless all_names contains post.category %}{% assign all_names = all_names | push: post.category %}{% endunless %}{% endif %}{% for tag in post.tags %}{% unless all_names contains tag %}{% assign all_names = all_names | push: tag %}{% endunless %}{% endfor %}{% endfor %}{% assign all_names = all_names | sort %}[{% for name in all_names %}{% assign count = 0 %}{% for post in site.posts %}{% if post.category == name or post.tags contains name %}{% assign count = count | plus: 1 %}{% endif %}{% endfor %}{"name":{{ name | jsonify }},"url":{{ site.url | append: site.baseurl | append: "/api/v1/categories/" | append: name | append: ".json" | jsonify }},"count":{{ count }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
