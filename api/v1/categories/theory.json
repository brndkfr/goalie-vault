---
layout: none
permalink: /api/v1/categories/theory.json
---
{% assign filtered = "" | split: "" %}{% for post in site.posts %}{% if post.category == 'theory' or post.tags contains 'theory' %}{% assign filtered = filtered | push: post %}{% endif %}{% endfor %}[{% for post in filtered %}{"title":{{ post.title | jsonify }},"author":{{ post.author | jsonify }},"handle":{{ post.handle | jsonify }},"platform":{{ post.platform | jsonify }},"video_id":{{ post.video_id | jsonify }},"category":{{ post.category | jsonify }},"tags":{{ post.tags | jsonify }},"description":{{ post.description | jsonify }},{% assign _td = site.data.thumbnails[post.video_id] %}{% if _td and _td.url and _td.status != "not_found" %}{% capture _thumb %}https://wsrv.nl/?url={{ _td.url | url_encode }}{% endcapture %}"thumbnail":{{ _thumb | jsonify }}{% elsif post.platform == "youtube" %}"thumbnail":{{ post.video_id | prepend: "https://img.youtube.com/vi/" | append: "/hqdefault.jpg" | jsonify }}{% else %}"thumbnail":null{% endif %},"url":{{ site.url | append: site.baseurl | append: post.url | jsonify }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
